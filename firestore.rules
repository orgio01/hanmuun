rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin email ──────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == "blackzebra617@gmail.com";
    }

    // ── Authenticated user ───────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ── Products ─────────────────────────────────────────────────────────
    match /products/{productId} {
      // Anyone can read approved products
      allow read: if true;

      // Admin can do anything
      allow write: if isAdmin();

      // Sellers can CREATE (status must be "pending", sellerId must be their uid)
      allow create: if isAuth()
                    && request.resource.data.status == "pending"
                    && request.resource.data.sellerId == request.auth.uid;

      // Sellers can UPDATE only their own pending products
      allow update: if isAuth()
                    && resource.data.sellerId == request.auth.uid
                    && resource.data.status == "pending"
                    && request.resource.data.status == "pending";

      // Sellers can DELETE their own pending products
      allow delete: if isAuth()
                    && resource.data.sellerId == request.auth.uid
                    && resource.data.status == "pending";
    }

    // ── Sellers collection ───────────────────────────────────────────────
    match /sellers/{uid} {
      // Seller өөрийн мэдээлэл унших
      allow read: if isAuth() && request.auth.uid == uid;
      // Seller бүртгэл үүсгэх (approved хэзээ ч true биш)
      allow create: if isAuth() && request.auth.uid == uid
                    && request.resource.data.approved == false;
      // Seller approved-г өөрчлөх эрхгүй
      allow update: if isAuth() && request.auth.uid == uid
                    && request.resource.data.approved == resource.data.approved;
      // Admin бүх зүйл
      allow read, write: if isAdmin();
    }

    // ── Users collection ────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // ── Reviews ─────────────────────────────────────────────────────────
    match /reviews/{productId}/items/{uid} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    // ── Coupons ─────────────────────────────────────────────────────────
    match /coupons/{code} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Banners ──────────────────────────────────────────────────────────
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Default: block all ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
